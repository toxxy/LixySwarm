[Unit]
Description=LixySwarm API (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/lixyswarm
ExecStart=/opt/lixyswarm/venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8080 --workers 1
Restart=on-failure
RestartSec=5
Environment=PYTHONPATH=/opt/lixyswarm

[Install]
WantedBy=multi-user.target
